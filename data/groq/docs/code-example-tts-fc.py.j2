import os
import requests

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")

def generate_tts(input_text: str, voice: str = "Fritz-PlayAI", fmt: str = "wav"):
    url = "https://api.groq.com/openai/v1/audio/speech"
    headers = {"Authorization": f"Bearer {UNITYSVC_API_KEY}", "Content-Type": "application/json"}

    payload = {
        "model": os.environ.get("MODEL", "{{offering.name}}"),
        "input": input_text,
        "voice": voice,
        "response_format": fmt
    }

    response = requests.post(url, headers=headers, json=payload)

    output_file = f"tts_output1.{fmt}"
    with open(output_file, "wb") as f:
        f.write(response.content)

    return {"file": output_file, "status": response.status_code}

# Example call
print(generate_tts("I love building and shipping new features for our users!"))

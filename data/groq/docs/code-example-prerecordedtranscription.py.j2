import os
import requests

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")

url = "https://api.groq.com/openai/v1/audio/transcriptions"
headers = {"Authorization": f"Bearer {UNITYSVC_API_KEY}"}

files = {
    "file": ("obamacompressed.mp4", open("obamacompressed.mp4", "rb")),
    "model": (None, os.environ.get("MODEL", "{{offering.name}}"))
}

response = requests.post(url, headers=headers, files=files)

print("Status:", response.status_code)
print(response.text)
